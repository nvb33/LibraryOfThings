<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             x:Class="StarterApp.Views.SubmitReviewPage"
             x:DataType="viewmodels:SubmitReviewViewModel"
             Title="Leave a Review">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Item title -->
            <Label Text="{Binding ItemTitle}"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="How would you rate this item?"
                   FontSize="16"
                   HorizontalOptions="Center" />

            <!-- Star rating buttons -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                <Button Text="★"
                        FontSize="32"
                        BackgroundColor="Transparent"
                        TextColor="{Binding Star1Colour}"
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="1" />
                <Button Text="★"
                        FontSize="32"
                        BackgroundColor="Transparent"
                        TextColor="{Binding Star2Colour}"
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="2" />
                <Button Text="★"
                        FontSize="32"
                        BackgroundColor="Transparent"
                        TextColor="{Binding Star3Colour}"
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="3" />
                <Button Text="★"
                        FontSize="32"
                        BackgroundColor="Transparent"
                        TextColor="{Binding Star4Colour}"
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="4" />
                <Button Text="★"
                        FontSize="32"
                        BackgroundColor="Transparent"
                        TextColor="{Binding Star5Colour}"
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="5" />
            </HorizontalStackLayout>

            <Label Text="{Binding Rating, StringFormat='{0} out of 5'}"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <!-- Comment -->
            <Label Text="Comment (optional)" FontAttributes="Bold" />
            <Editor Text="{Binding Comment, Mode=TwoWay}"
                    Placeholder="Share your experience..."
                    HeightRequest="120"
                    MaxLength="500" />
            <Label Text="{Binding Comment.Length, StringFormat='{0}/500 characters'}"
                   TextColor="Gray"
                   FontSize="12"
                   HorizontalOptions="End" />

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding ErrorMessage,
                       Converter={StaticResource StringToBoolConverter}}" />

            <!-- Loading spinner -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <!-- Submit button -->
            <Button Text="Submit Review"
                    Command="{Binding SubmitReviewCommand}"
                    IsEnabled="{Binding IsBusy,
                        Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="#512BD4"
                    TextColor="White" />

            <!-- Cancel button -->
            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsBusy,
                        Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="#E0E0E0"
                    TextColor="Black" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>