<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             xmlns:models="clr-namespace:StarterApp.Database.Models;assembly=StarterApp.Database"
             x:Class="StarterApp.Views.ItemsListPage"
             x:DataType="viewmodels:ItemsListViewModel"
             Title="Available Items">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Add Item"
                     Command="{Binding NavigateToCreateCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">

        <!-- Loading spinner -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           Margin="0,8" />

        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding ErrorMessage,
               Converter={StaticResource StringToBoolConverter}}"
               HorizontalOptions="Center"
               Margin="16" />

        <!-- Empty state -->
        <Label Grid.Row="1"
               Text="No items found. Add one using the button above."
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="Gray"
               HorizontalTextAlignment="Center"
               Margin="32" />

        <!-- Items list -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Item">
                    <Border Margin="12,6"
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#E0E0E0">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto">

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="16" />

                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding FormattedRate}"
                                   TextColor="Green"
                                   FontAttributes="Bold" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Category.Name}"
                                   TextColor="Gray"
                                   FontSize="13" />

                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding AvailabilityText}"
                                   FontSize="13"
                                   TextColor="Gray" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ItemsListViewModel}}, Path=NavigateToDetailCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>