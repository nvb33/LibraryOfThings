<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             xmlns:models="clr-namespace:StarterApp.Database.Models;assembly=StarterApp.Database"
             x:Class="StarterApp.Views.ItemsListPage"
             x:DataType="viewmodels:ItemsListViewModel"
             Title="Available Items">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Add Item"
                     Command="{Binding NavigateToCreateCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

        <!-- Search bar — Row 0 -->
        <SearchBar Grid.Row="0"
                   Text="{Binding SearchQuery, Mode=TwoWay}"
                   Placeholder="Search by title..."
                   Margin="12,8" />

        <!-- Owner filter — Row 1 -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*"
              Margin="16,4">
            <Label Grid.Column="0"
                   Text="Owner:"
                   VerticalOptions="Center"
                   FontSize="14"
                   Margin="0,0,8,0" />
            <Picker Grid.Column="1"
                    ItemsSource="{Binding OwnerFilters}"
                    SelectedItem="{Binding SelectedOwnerFilter, Mode=TwoWay}"
                    Title="All owners" />
        </Grid>

        <!-- Sort options — Row 2 -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*"
              Margin="16,4">
            <Label Grid.Column="0"
                   Text="Sort:"
                   VerticalOptions="Center"
                   FontSize="14"
                   Margin="0,0,8,0" />
            <Picker Grid.Column="1"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                    Title="Default" />
        </Grid>

        <!-- Loading spinner — Row 3 -->
        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           Margin="0,4" />

        <!-- Error message — Row 4 -->
        <Label Grid.Row="4"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding ErrorMessage,
                   Converter={StaticResource StringToBoolConverter}}"
               HorizontalOptions="Center"
               Margin="16" />

        <!-- Empty state + Items list — Row 5 -->
        <Label Grid.Row="5"
               Text="No items match your search."
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="Gray"
               HorizontalTextAlignment="Center"
               Margin="32" />

        <RefreshView Grid.Row="5"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadItemsCommand}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Item">
                        <Border Margin="12,6"
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto">

                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="16" />

                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding DailyRate, StringFormat='£{0:F2}/day'}"
                                       TextColor="Green"
                                       FontAttributes="Bold" />

                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding CategoryName}"
                                       TextColor="Gray"
                                       FontSize="13" />

                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding AvailabilityText}"
                                       FontSize="13"
                                       TextColor="Gray" />

                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                       TextColor="Gray"
                                       FontSize="12" />

                                <Label Grid.Row="2" Grid.Column="1"
                                       Text="{Binding FormattedRating}"
                                       TextColor="#FFD700"
                                       FontSize="12" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ItemsListViewModel}}, Path=NavigateToDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>